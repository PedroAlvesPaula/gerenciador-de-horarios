generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// O Enum define as roles
enum Role {
  ADMIN
  CUSTOMER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}